#!/usr/bin/env bash

function rand() {
    n=$1
    fmt=$2
    od -An -tu4 /dev/random | head -n${n} | awk -F ' ' "{print $fmt}" | bc
}

function diceware() {
    n=$1
    wordlist=$2
    special="!"
    if [ $(rand 1 '$1 % 2') -eq 1 ]; then
        special="?"
    fi
    digit=$(rand 1 '$1 % 10')
    words=$(rand $n '$1 % 7776 + 1' | xargs -I% sed -n "%p" $wordlist | paste -s -d ' ' -)
    first_letter=$(echo $words | cut -c1)
    first_letter_upper=$(echo $first_letter | tr '[:lower:]' '[:upper:]')
    echo $words | sed "s/^$first_letter\(.*\)/$digit $first_letter_upper\1$special/"
}

function force-curses() {
    export GPG_TTY=$(tty)
    export PINENTRY_USER_DATA="USE_CURSES=1"
    export DISPLAY=""
}

function fullprompt() {
    read -p "Username: " user
    pw=$(pwprompt)
    if [ $? -ne 0 ]; then
        exit $?
    fi
    value="${user}"$'\n'"${pw}"
    echo "$value"
}

function pwprompt() {
    read -s -p "Password: " pw
    read -s -p "Again: " pwcheck

    if [ ! "$pw" == "$pwcheck" ]; then
        echo "Passwords do not match" >&2
        exit -1
    fi
    unset -v pwcheck
    echo $pw
}

fzfprg="fzf"

if [ "$(uname)" == "Darwin" ]; then
    clip="pbcopy"
    paste="pbpaste"
else
    clip="xclip -selection clipboard"
    paste="xclip -selection clipboard -o"
fi

pwdir="${HOME}/.pstore"
master_file="${pwdir}/assets/master"
unlock_file="${pwdir}/assets/unlock"
if [ ! -d $pwdir ]; then
    mkdir $pwdir
fi

if [ "$1" == "add" ]; then
    if [ $# -ne 2 ]; then
        echo "Usage: p add <key>"
        exit -2
    fi
    key=$2
    filename="${pwdir}/${key}"
    value=$(fullprompt)
    if [ $? -ne 0 ]; then
        exit $?
    fi

    force-curses
    master=$(gpg -d $master_file)
    unlock=$(gpg -d --no-symkey-cache $unlock_file)
    echo -n "$value" | gpg -c --armor --no-symkey-cache --passphrase ${master} --batch | gpg -c --armor --no-symkey-cache --passphrase ${unlock} --batch > $filename
    unset -v master
    unset -v unlock
elif [ "$1" == "diceware" ]; then
    if [ "$#" -lt 2 ]; then
        echo "Usage: p diceware n"
        exit -1
    fi
    diceware $2 ${pwdir}/assets/diceware-german.txt
elif [ "$1" == "unlock" ]; then
    gpg -d $master_file > /dev/null
elif [ "$1" == "clear" ]; then
    echo -n "Cleared!" | $clip
else
    show=0
    if [ "$1" == "--gui" ]; then
        fzfprg="gfzf"
    else
        if [ "$1" == "--show" ]; then
            show=1
        fi
        force-curses
    fi
    key=$(ls $pwdir | $fzfprg)
    if [ "$key" == "" ]; then
        exit 0
    fi

    clip_bak=$(${paste})
    master=$(gpg -d $master_file)
    unlock=$(gpg -d --no-symkey-cache $unlock_file)
    plain=$(gpg -d --no-symkey-cache --passphrase ${unlock} --batch ${pwdir}/${key} | gpg -d --no-symkey-cache --passphrase ${master} --batch)
    unset -v master
    unset -v unlock
    if [ $? -ne 0 ]; then
        exit -1
    fi
    if [ $show -eq 1 ]; then
        echo "$plain"
    else
        echo -n "$plain" | head -n1
    fi

    echo -n "$plain" | tail -n1 | sed 's/ //g' | $clip
    unset -v plain
    echo "Resetting clipboard in 10 seconds ..."
    sleep 10
    echo -n "$clip_bak" | $clip
fi
