theme = Catppuccin Frappe
cursor-color = #8caaee

gtk-titlebar = false
gtk-toolbar-style = flat

keybind = cmd+c=copy_to_clipboard
keybind = cmd+v=paste_from_clipboard

keybind = ctrl+a>c=new_tab
keybind = ctrl+one=goto_tab:1
keybind = ctrl+two=goto_tab:2
keybind = ctrl+three=goto_tab:3
keybind = ctrl+four=goto_tab:4
keybind = ctrl+five=goto_tab:5

keybind = ctrl+a>shift+2=new_split:down
keybind = ctrl+a>shift+5=new_split:right
keybind = ctrl+a>shift+0=equalize_splits
keybind = ctrl+a>k=resize_split:up,200
keybind = ctrl+a>j=resize_split:down,200

keybind = performable:ctrl+tab=goto_split:next
keybind = performable:ctrl+y=goto_split:next

keybind = ctrl+shift+f=start_search
keybind = cmd+page_up=scroll_page_up
keybind = cmd+page_down=scroll_page_down

keybind = ctrl+a>ctrl+r=reload_config

config-file = ?local-config
